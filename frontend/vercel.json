{
  "buildCommand": "echo 'No build needed'",
  "installCommand": "npm install express cors uuid @babel/core @babel/standalone",
  "framework": "static",
  "routes": [
    { "src": "/api/projects", "dest": "/api/index.js" },
    { "src": "/api/projects/(.*)", "dest": "/api/index.js" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}